datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum ProjectStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  ON_HOLD
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

model User {
  id             String    @id @default(uuid())
  name           String
  email          String    @unique
  passwordHash   String
  role           Role      @default(EMPLOYEE)
  managerId      String?
  department     String?
  designation    String?
  joiningDate    DateTime? @default(now())
  contactNumber  String?
  profilePicture String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Self-referencing manager relation
  manager      User?  @relation("UserManager", fields: [managerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  subordinates User[] @relation("UserManager")

  // Projects managed by this user
  managedProjects Project[] @relation("ProjectManager")

  // Projects this user is a member of
  projects ProjectMember[]

  // Attendance records
  attendance Attendance[] @relation("UserAttendance")

  // Performance reviews received by this employee
  reviewsReceived PerformanceReview[] @relation("EmployeeReviews")

  // Performance reviews written by this user
  reviewsGiven PerformanceReview[] @relation("ReviewerReviews")
}

model Project {
  id          String        @id @default(uuid())
  name        String
  description String?
  startDate   DateTime      @default(now())
  endDate     DateTime?
  status      ProjectStatus @default(NOT_STARTED)
  priority    ProjectPriority @default(MEDIUM)
  managerId   String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Manager of the project
  manager User @relation("ProjectManager", fields: [managerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // Members of the project
  members ProjectMember[]
}

model ProjectMember {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model Attendance {
  id         String           @id @default(uuid())
  employeeId String
  date       DateTime         @db.Date
  checkIn    DateTime
  checkOut   DateTime?
  status     AttendanceStatus @default(PRESENT)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  employee User @relation("UserAttendance", fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
}

model PerformanceReview {
  id              String   @id @default(uuid())
  employeeId      String
  reviewerId      String
  technicalSkills Int      // 1-5
  communication   Int      // 1-5
  teamwork        Int      // 1-5
  problemSolving  Int      // 1-5
  leadership      Int      // 1-5
  comments        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employee User @relation("EmployeeReviews", fields: [employeeId], references: [id], onDelete: Cascade)
  reviewer User @relation("ReviewerReviews", fields: [reviewerId], references: [id], onDelete: Cascade)
}
